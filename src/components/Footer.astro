---
import { GITHUB_LINK, GITHUB_ICON } from '../consts';
const today = new Date();
---
<footer class="bg-gray-900 text-white font-header">
  <p class="text-sm md:text-base">&copy; {today.getFullYear()} Brandon Romero, All rights reserved.</p>
  <div class="social-links" title="Check out my github">
    <a href={GITHUB_LINK} target="_blank" class="hover:scale-115">
      <svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32">
        <path fill="currentColor" d={GITHUB_ICON}></path>
      </svg>
    </a>
  </div>
</footer>
<style>
  footer {
    text-align: center;
    width: 100%;
    padding: 2rem 1rem;
  }
  .social-links {
    display: flex;
    justify-content: center;
    margin-top: 0.5rem;
  }
  .social-links a {
    text-decoration: none;
    color: white;
  }
</style>
