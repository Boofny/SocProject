---
const icon = "https://cdn-icons-png.flaticon.com/128/2602/2602412.png"
import { REPO_LINK, GITHUB_ICON } from '../consts';
---

<header class="bg-gray-900 border-b border-gray-400 relative">
  <nav class="mx-auto px-4 sm:px-6 lg:px-8">
    <div class="relative flex items-center justify-center h-16 w-full ">

      <a title="Our School" href="https://www.dtcc.edu/" class="hover:scale-110 ease-in-out absolute left-0 flex items-center shrink-0 " target="_blank" rel="noopener noreferrer">
        <div class="w-12 h-12 rounded-lg bg-gray-200 hover:bg-amber-200 flex items-center justify-center">
          <img src={icon} class="w-10 h-10" alt="icon"/>
        </div>
      </a>

      <div class="flex font-header items-center gap-0.5 ml-5">
        <a href="/" class="rounded relative text-gray-100 hover:bg-white/6 hover:text-white px-3.5  py-1.5 text-xl">
          Home
        </a>
        <a href="/about" class="rounded relative text-gray-100 hover:bg-white/6 hover:text-white px-3.5 py-1.5 text-xl font-medium">
          About
        </a>
      </div>
      <a title="Check out the git repo!" href={REPO_LINK} target="_blank" class="text-white rounded hover:scale-115 hover:text-yellow-200 hover:rotate-12 ease-in-out absolute right-0 ">
          <svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32">
            <path fill="currentColor" d={GITHUB_ICON}></path>
          </svg>
        </a>
      <!-- </div> -->
    </div>
  </nav>
</header>
