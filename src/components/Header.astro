---
const icon = "https://cdn-icons-png.flaticon.com/128/2602/2602412.png"
---

<header class="bg-gray-800 border-b border-gray-400 relative">
  <nav class="mx-auto px-4 sm:px-6 lg:px-8">
    <div class="relative flex items-center justify-center h-16 w-full ">

      <a href="https://www.dtcc.edu/" class="hover:scale-110 ease-in-out absolute left-0 flex items-center shrink-0 " target="_blank" rel="noopener noreferrer">
        <div class="w-12 h-12 rounded-lg bg-gray-200 flex items-center justify-center">
          <img src={icon} class="w-10 h-10" alt="icon"/>
        </div>
      </a>

      <div class="flex font-header items-center gap-0.5 ml-5">
        <a href="/" class="rounded relative text-gray-100 hover:bg-white/6 hover:text-white px-3.5  py-1.5 text-xl">
          Home
        </a>
        <a href="/about" class="rounded relative text-gray-100 hover:bg-white/6 hover:text-white px-3.5 py-1.5 text-xl font-medium">
          About
        </a>
      </div>

    </div>
  </nav>
</header>
